  "query": "\n            SELECT\n                id, tenant_id, name, description, status,\n                sku_code, jan_code, upc_code, kind,\n                billing_cycle, list_price, publication_status,\n                publication_name, publication_description,\n                file_ids,\n                category_id, weight_grams,\n                created_at, updated_at\n            FROM tachyon_apps_order.products\n            WHERE tenant_id = ? AND name LIKE ?\n            ORDER BY created_at DESC\n            ",
