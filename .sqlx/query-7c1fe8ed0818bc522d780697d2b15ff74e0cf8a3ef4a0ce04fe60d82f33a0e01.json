{
  "db_name": "MySQL",
  "query": "\n            SELECT \n                p.id, p.contract_id, p.resource_type, p.unit_type,\n                p.base_cost, p.currency, p.tier_pricing as \"tier_pricing: serde_json::Value\",\n                p.effective_from, p.effective_until, p.description,\n                p.created_at, p.updated_at\n            FROM procurement_prices p\n            INNER JOIN supply_contracts c ON p.contract_id = c.id\n            WHERE p.resource_type = ?\n                AND p.effective_from <= ?\n                AND (p.effective_until IS NULL OR p.effective_until >= ?)\n                AND c.status = 'ACTIVE'\n            ORDER BY p.effective_from DESC\n            LIMIT 1\n            ",
