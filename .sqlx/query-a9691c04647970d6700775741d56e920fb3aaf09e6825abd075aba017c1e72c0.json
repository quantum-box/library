  "db_name": "MySQL",
  "query": "\n            SELECT\n                id, tenant_id, sku_id,\n                strategy as \"strategy: Value\",\n                floor_price, ceiling_price,\n                effective_from, effective_until,\n                description, created_at, updated_at\n            FROM tachyon_apps_pricing.pricing_rate_cards\n            WHERE tenant_id = ?\n              AND sku_id = ?\n              AND effective_from <= ?\n              AND (effective_until IS NULL\n                   OR effective_until > ?)\n            ORDER BY effective_from DESC\n            LIMIT 1\n            ",
