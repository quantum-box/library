  "db_name": "MySQL",
  "query": "\n            SELECT\n                id, tenant_id, cart_id, user_id, session_id,\n                status, fulfillment_method, payment_method,\n                shipping_name, shipping_address,\n                shipping_phone, subtotal_nanodollar,\n                shipping_fee_nanodollar, total_nanodollar,\n                stripe_checkout_session_id,\n                confirmed_at, shipped_at, delivered_at,\n                cancelled_at, pickup_deadline, ready_at,\n                picked_up_at, created_at, updated_at\n            FROM tachyon_apps_order.consumer_orders\n            WHERE tenant_id = ? AND session_id = ?\n              AND (? = FALSE OR id < ?)\n              AND (? = FALSE OR id > ?)\n            ORDER BY id DESC\n            LIMIT ?\n            ",
