  "query": "\n            SELECT\n                id, tenant_id, product_id, movement_type,\n                quantity, reference_type, reference_id,\n                note, created_at\n            FROM tachyon_apps_order.stock_movements\n            WHERE tenant_id = ? AND product_id = ?\n              AND (? = FALSE OR id < ?)\n              AND (? = FALSE OR id > ?)\n            ORDER BY id DESC\n            LIMIT ?\n            ",
