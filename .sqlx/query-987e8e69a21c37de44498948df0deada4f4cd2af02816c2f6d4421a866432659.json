  "query": "SELECT t.id, t.name, t.user_name, t.parent_tenant_id, t.created_at, t.updated_at \n             FROM tachyon_apps_auth.tenants t\n             JOIN tachyon_apps_auth.tenants p ON t.parent_tenant_id = p.id\n             JOIN tachyon_apps_auth._tenant_to_user tu ON t.id = tu.a\n             WHERE tu.b = ? AND p.parent_tenant_id IS NOT NULL ORDER BY t.created_at DESC",
